# Generated by Ansible - Traefik Helm values
# Compatible with Traefik Helm chart v33+ (Traefik v3)
# Ref: https://github.com/traefik/traefik-helm-chart/blob/master/EXAMPLES.md

# IngressClass configuration
ingressClass:
  enabled: {{ traefik_ingressclass_enabled | lower }}
  isDefaultClass: {{ traefik_ingressclass_default | lower }}

# Entrypoints
ports:
  web:
    exposedPort: {{ traefik_web_exposed_port }}
{% if traefik_redirect_http_to_https %}
    # Traefik Helm chart v33+ redirect syntax
    # Replaces the removed 'redirectTo' property
    http:
      redirections:
        entryPoint:
          to: websecure
          scheme: https
          permanent: true
{% endif %}
  websecure:
    exposedPort: {{ traefik_websecure_exposed_port }}
    tls:
      enabled: true

# Service configuration
service:
  type: {{ traefik_service_type }}

# Deployment
deployment:
  replicas: {{ traefik_replicas }}

# Resources
resources:
  requests:
    cpu: "{{ traefik_cpu_request }}"
    memory: "{{ traefik_memory_request }}"
  limits:
    cpu: "{{ traefik_cpu_limit }}"
    memory: "{{ traefik_memory_limit }}"

# Logging
logs:
  general:
    level: {{ traefik_log_level }}
  access:
    enabled: {{ traefik_access_log_enabled | lower }}
